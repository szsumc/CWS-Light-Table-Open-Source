{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://szsumc.github.io/CWS-Light-Table-Docs/cws-html-workbook-model-v1.schema.json",
  "title": "CWS Light Table Workbook Model",
  "type": "object",
  "required": [
    "version",
    "sourceName",
    "saveType",
    "activeSheetIndex",
    "sheets"
  ],
  "properties": {
    "version": {
      "type": "integer"
    },
    "sourceName": {
      "type": "string"
    },
    "saveType": {
      "type": "string",
      "const": "html"
    },
    "createdAt": {
      "type": "string"
    },
    "activeSheetIndex": {
      "type": "integer",
      "minimum": 0
    },
    "showFormulaBar": {
      "type": "boolean"
    },
    "definedNames": {
      "type": "array"
    },
    "relationships": {
      "type": "array"
    },
    "workbookProperties": {
      "type": "object"
    },
    "calcProperties": {
      "type": "object"
    },
    "sheets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "rowCount",
          "colCount",
          "cells"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "rowCount": {
            "type": "integer",
            "minimum": 1
          },
          "colCount": {
            "type": "integer",
            "minimum": 1
          },
          "defaultColumnWidth": {
            "type": "number"
          },
          "defaultRowHeight": {
            "type": "number"
          },
          "zoomScale": {
            "type": "number"
          },
          "displayScale": {
            "type": "number"
          },
          "defaultCellCss": {
            "type": "object"
          },
          "columns": {
            "type": "array"
          },
          "rows": {
            "type": "array"
          },
          "merges": {
            "type": "array"
          },
          "images": {
            "type": "array"
          },
          "inkStrokes": {
            "type": "array"
          },
          "autoFilter": {},
          "pageLayout": {
            "type": "object"
          },
          "cwsLight": {
            "type": "object",
            "properties": {
              "headerRowIndex": {
                "type": "integer",
                "minimum": 1
              },
              "gridLimits": {
                "type": "object",
                "properties": {
                  "maxRows": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "maxColumns": {
                    "type": "integer",
                    "minimum": 1
                  }
                },
                "required": [
                  "maxRows",
                  "maxColumns"
                ]
              }
            }
          },
          "cells": {
            "type": "object",
            "patternProperties": {
              "^[0-9]+:[0-9]+$": {
                "type": "object",
                "required": [
                  "row",
                  "col"
                ],
                "properties": {
                  "row": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "col": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "raw": {
                    "type": [
                      "string",
                      "number",
                      "boolean",
                      "null"
                    ]
                  },
                  "display": {
                    "type": "string"
                  }
                }
              }
            },
            "additionalProperties": false
          }
        }
      }
    }
  }
}
